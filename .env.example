# Copy to .env for local dev. .env is gitignored.
# In production, set the same variable in the Netlify UI under
# Site settings → Environment variables (Vite reads it at build time).

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX). Leave empty to disable.
VITE_GA_MEASUREMENT_ID=

# Email to send with Unpaywall API calls (required by their ToS). Defaults to
# a generic noreply if unset; setting a real contact email is preferred for
# production deployments so they can reach you if there's a problem.
VITE_UNPAYWALL_EMAIL=
