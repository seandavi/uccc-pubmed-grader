# Copy to .env for local dev. .env is gitignored.
# In production, these are populated from GCP Secret Manager at deploy time.

# iCite API
ICITE_BASE_URL=https://icite.od.nih.gov/api
ICITE_BATCH_SIZE=200
ICITE_TIMEOUT_SECONDS=30

# App
LOG_LEVEL=INFO
MAX_UPLOAD_BYTES=52428800  # 50 MiB
JOB_TTL_SECONDS=3600

# Frontend (dev only — Vite reads VITE_* at build time)
VITE_API_BASE=http://localhost:8000
